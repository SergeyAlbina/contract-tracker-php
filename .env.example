# ═══ Database (MySQL) ═══
DB_HOST=localhost
DB_PORT=3306
DB_NAME=contract_tracker
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ═══ App ═══
APP_DEBUG=true
APP_SECRET=CHANGE_THIS_TO_RANDOM_64_CHARS

# ═══ Session ═══
SESSION_LIFETIME=3600
# Для production (HTTPS) переключите в true
SESSION_SECURE=false

# ═══ Storage ═══
STORAGE_PATH=storage
UPLOAD_ALLOWED_EXT=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,zip,rar,7z
UPLOAD_MAX_SIZE=10485760

# ═══ Telegram (опционально) ═══
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
