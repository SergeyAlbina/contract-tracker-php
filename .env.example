# ===========================
# Contract Tracker .env.example
# ===========================

# --- App ---
NODE_ENV=development
APP_NAME=contract-tracker
APP_URL=http://localhost:3000

# --- API ---
API_PORT=4000
API_BASE_PATH=/api/v1
CORS_ORIGINS=http://localhost:3000

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- Database (MySQL) ---
DATABASE_URL=mysql://contract:contract@localhost:3306/contract_tracker

# --- Storage driver ---
# local (v1) or s3 (v2)
STORAGE_DRIVER=local
STORAGE_LOCAL_ROOT=./storage
UPLOAD_MAX_MB=50

# --- S3 / MinIO (v2) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=contracts

# --- Telegram notifications ---
TELEGRAM_BOT_TOKEN=change_me
TELEGRAM_CHAT_ID=change_me_chat_id

# --- Export / rendering ---
EXPORT_TMP_DIR=./tmp/exports

# --- Feature flags / policies ---
FEATURE_2FA_ENABLED=false

# --- Logging ---
LOG_LEVEL=info
