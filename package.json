{
  "name": "contract-tracker",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev:api": "pnpm --filter @ct/api dev",
    "dev:web": "pnpm --filter @ct/web dev",
    "build:api": "pnpm --filter @ct/api build",
    "build:web": "pnpm --filter @ct/web build",
    "db:migrate": "pnpm --filter @ct/api db:migrate",
    "db:generate": "pnpm --filter @ct/api db:generate",
    "db:studio": "pnpm --filter @ct/api db:studio",
    "db:seed": "pnpm --filter @ct/api db:seed",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
